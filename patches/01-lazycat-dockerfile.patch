diff --git a/lazycat-entrypoint.sh b/lazycat-entrypoint.sh
new file mode 100644
index 0000000..5ff75da
--- /dev/null
+++ b/lazycat-entrypoint.sh
@@ -0,0 +1,34 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+PERSIST_DIR=${LZC_PERSIST_DIR:-/lzcapp/var/data}
+LOGS_DIR=${LZC_LOGS_DIR:-/lzcapp/var/logs}
+
+mkdir -p "${PERSIST_DIR}" "${LOGS_DIR}" /tmp
+
+# LanceDB stores tables on disk relative to process.cwd() when type=local.
+# Symlink into the persist volume so vector data survives restarts.
+mkdir -p "${PERSIST_DIR}/lancedb"
+ln -sfn "${PERSIST_DIR}/lancedb" /app/vector/data
+mkdir -p /app/vector/data
+
+# Don't block on redis-http here. SRH does not expose a 200-on-GET liveness
+# endpoint (`/ping` returns 404; the protocol uses POST `/` with a JSON
+# command array), so any naive wait loop just churns until the lazycat
+# health-check kills us at start_period. Let supervisord come up
+# immediately — frontend's @upstash/redis client and next-auth adapter
+# retry their own connections, and SRH is normally ready by then anyway.
+
+# Pin VECTOR_HOST to the loopback service inside this container even if a
+# user (or a leftover env from upstream's Vercel deployment) overrides it.
+export VECTOR_HOST="http://127.0.0.1:3001"
+export VECTOR_INDEX_HOST="http://127.0.0.1:3001"
+
+# next-auth (frontend) signs the JWT with AUTH_SECRET; vector decrypts it
+# with JWT_SECRET. They MUST be identical or session-protected vector
+# routes reject every request with 401.
+if [[ -n "${AUTH_SECRET:-}" ]] && [[ -z "${JWT_SECRET:-}" ]]; then
+  export JWT_SECRET="${AUTH_SECRET}"
+fi
+
+exec /usr/bin/supervisord -c /app/supervisord.conf
diff --git a/nginx.conf b/nginx.conf
new file mode 100644
index 0000000..d666948
--- /dev/null
+++ b/nginx.conf
@@ -0,0 +1,72 @@
+worker_processes 1;
+error_log /dev/stderr warn;
+pid /tmp/nginx.pid;
+
+events {
+    worker_connections 1024;
+}
+
+http {
+    include /etc/nginx/mime.types;
+    default_type application/octet-stream;
+    sendfile on;
+    tcp_nopush on;
+    tcp_nodelay on;
+    keepalive_timeout 65;
+    server_tokens off;
+
+    access_log /dev/stdout combined;
+
+    client_max_body_size 100M;
+    proxy_read_timeout 600s;
+    proxy_send_timeout 600s;
+    proxy_buffering off;
+    proxy_request_buffering off;
+
+    upstream frontend_upstream {
+        server 127.0.0.1:3000;
+        keepalive 32;
+    }
+
+    upstream vector_upstream {
+        server 127.0.0.1:3001;
+        keepalive 16;
+    }
+
+    server {
+        listen 80 default_server;
+        listen [::]:80 default_server;
+        server_name _;
+
+        location = /health {
+            access_log off;
+            default_type text/plain;
+            return 200 'ok\n';
+        }
+
+        # File upload endpoint that the browser calls directly on the
+        # vector service (use-upload-file.ts). Authenticated via JWT
+        # cookie inside vector/auth.ts, so it is safe to expose.
+        location = /api/index/local-file {
+            proxy_pass http://vector_upstream;
+            proxy_http_version 1.1;
+            proxy_set_header Host $host;
+            proxy_set_header X-Real-IP $remote_addr;
+            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+            proxy_set_header X-Forwarded-Proto $scheme;
+            proxy_set_header Cookie $http_cookie;
+        }
+
+        # Everything else goes to Next.js
+        location / {
+            proxy_pass http://frontend_upstream;
+            proxy_http_version 1.1;
+            proxy_set_header Host $host;
+            proxy_set_header X-Real-IP $remote_addr;
+            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+            proxy_set_header X-Forwarded-Proto $scheme;
+            proxy_set_header Upgrade $http_upgrade;
+            proxy_set_header Connection "upgrade";
+        }
+    }
+}
diff --git a/supervisord.conf b/supervisord.conf
new file mode 100644
index 0000000..ef47332
--- /dev/null
