@@ -0,0 +1,94 @@
+# syntax=docker/dockerfile:1
+ARG BUN_VERSION=1.1.34
+FROM oven/bun:${BUN_VERSION}-slim AS base
+ENV NODE_ENV="production" \
+    DEBIAN_FRONTEND=noninteractive
+
+# ---------- Frontend build ----------
+FROM base AS frontend-build
+WORKDIR /app/frontend
+
+RUN apt-get update -qq \
+    && apt-get install --no-install-recommends -y \
+       build-essential pkg-config python-is-python3 ca-certificates \
+    && apt-get clean && rm -rf /var/lib/apt/lists/*
+
+COPY --link frontend/package.json frontend/bun.lockb ./
+RUN bun install --frozen-lockfile
+
+COPY --link frontend/ ./
+
+# Build-time env. Public URL is intentionally empty so emitted absolute URLs
+# fall back to relative paths and work behind any reverse proxy domain. The
+# remaining vars are placeholders just to satisfy module-load-time `if (!X)
+# throw` guards in lib/env.ts; real values are injected at runtime.
+ENV NEXT_TELEMETRY_DISABLED=1 \
+    NEXT_PUBLIC_APP_URL="" \
+    NEXT_PUBLIC_VECTOR_HOST="" \
+    VECTOR_HOST="http://127.0.0.1:3001" \
+    VECTOR_INDEX_HOST="http://127.0.0.1:3001" \
+    UPSTASH_REDIS_REST_URL="http://127.0.0.1:8079" \
+    UPSTASH_REDIS_REST_TOKEN="placeholder" \
+    API_TOKEN="placeholder" \
+    AUTH_SECRET="placeholder" \
+    OPENAI_API_KEY="placeholder" \
+    NEXT_PUBLIC_LAZYCAT_OIDC_ENABLED="1" \
+    SKIP_ENV_VALIDATION=1
+RUN bun run build
+
+
+# ---------- Vector deps ----------
+FROM base AS vector-build
+WORKDIR /app/vector
+
+RUN apt-get update -qq \
+    && apt-get install --no-install-recommends -y \
+       build-essential pkg-config python-is-python3 ca-certificates \
+    && apt-get clean && rm -rf /var/lib/apt/lists/*
+
+COPY --link vector/package.json vector/bun.lockb ./
+# --production drops devDependencies (bun-types, @flydotio/dockerfile, ...)
+RUN bun install --frozen-lockfile --production
+
+COPY --link vector/ ./
+
+
+# ---------- Runtime ----------
+# nodejs slim base — bun is 70MB+ stripped of dev tooling but Next.js
+# standalone produces a node-compatible server.js, so we don't need bun in
+# the final image. Vector still uses bun, so we copy the bun binary itself
+# in (~70MB) instead of dragging the whole oven/bun image.
+FROM debian:bookworm-slim AS runtime
+ENV NODE_ENV="production" \
+    DEBIAN_FRONTEND=noninteractive
+
+RUN apt-get update -qq \
+    && apt-get install --no-install-recommends -y \
+       nodejs nginx supervisor curl ca-certificates tini libstdc++6 \
+    && apt-get clean && rm -rf /var/lib/apt/lists/* /var/cache/apt/* \
+    && rm -rf /etc/nginx/sites-enabled/default /etc/nginx/conf.d/default.conf 2>/dev/null || true
+
+# Bun runtime for the vector service (only the binary, no global packages).
+COPY --from=base /usr/local/bin/bun /usr/local/bin/bun
+COPY --from=base /usr/local/bin/bunx /usr/local/bin/bunx
+
+WORKDIR /app
+
+# Frontend: standalone bundle = server.js + only-needed node_modules
+# subset, plus static assets and the public/ tree.
+COPY --from=frontend-build /app/frontend/.next/standalone /app/frontend
+COPY --from=frontend-build /app/frontend/.next/static /app/frontend/.next/static
+COPY --from=frontend-build /app/frontend/public /app/frontend/public
+
+# Vector: production-only node_modules + source.
+COPY --from=vector-build /app/vector /app/vector
+
+COPY nginx.conf /etc/nginx/nginx.conf
+COPY supervisord.conf /app/supervisord.conf
+COPY lazycat-entrypoint.sh /app/lazycat-entrypoint.sh
+RUN chmod +x /app/lazycat-entrypoint.sh \
+    && mkdir -p /app/data /app/logs /var/log/nginx /var/lib/nginx \
+    && touch /var/log/nginx/access.log /var/log/nginx/error.log
+
+EXPOSE 80
+ENTRYPOINT ["/usr/bin/tini","--","/app/lazycat-entrypoint.sh"]
